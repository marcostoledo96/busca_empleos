# === Variables de entorno para tests destructivos contra la base de datos ===
# Copiar este archivo como .env.test y ajustar los valores.
# NUNCA usar estas variables contra una base de datos de producción.
#
# ⚠️  TRIPLE GUARDA: los tests destructivos solo corren si se cumplen TODAS:
#   1. ALLOW_DB_TESTS=true
#   2. NODE_ENV=test
#   3. El nombre de la base de datos conectada termina en "_test"
#      (se verifica con SELECT current_database() en runtime)
#
# Si DATABASE_URL está configurada, PGDATABASE se ignora porque el pool
# usa DATABASE_URL primero. Asegurate de que la URL apunte a una BD "_test"
# o comentalá y usá las variables PG* individuales.

# === Flags de test (OBLIGATORIOS) ===
NODE_ENV=test
ALLOW_DB_TESTS=true

# === Base de datos de test ===
PGHOST=localhost
PGPORT=5432
PGDATABASE=busca_empleos_test
PGUSER=postgres
PGPASSWORD=tu_contraseña_aqui

# === DATABASE_URL (alternativa a las variables PG*) ===
# Si la usás, DEBE apuntar a una base de datos cuyo nombre termine en "_test".
# El guardián de tests verifica el nombre real de la BD conectada, no las variables.
# DATABASE_URL=postgresql://postgres:tu_contraseña@localhost:5432/busca_empleos_test
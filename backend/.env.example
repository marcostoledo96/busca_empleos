# === Base de datos ===
PGHOST=localhost
PGPORT=5432
PGDATABASE=busca_empleos
PGUSER=postgres
PGPASSWORD=tu_contraseña_aqui

# === Apify ===
APIFY_TOKEN=tu_token_de_apify

# === Jooble ===
# API key gratuita. Registrarse en: https://jooble.org/api/about
JOOBLE_API_KEY=tu_api_key_de_jooble

# === InfoJobs España (API oficial) ===
# Registrarse en: https://developer.infojobs.net para obtener las credenciales.
# Solo acepta ofertas de remoto puro (teleworking=solo-teletrabajo).
INFOJOBS_CLIENT_ID=tu_client_id_de_infojobs
INFOJOBS_CLIENT_SECRET=tu_client_secret_de_infojobs

# === Adzuna (API REST oficial) ===
# Registrarse en: https://developer.adzuna.com para obtener las credenciales.
# Requiere ambas variables para funcionar. Si solo una está presente, el servidor lanza error.
# Si ninguna está configurada, Adzuna se deshabilita automáticamente (soft-disable).
# Atribución requerida: el frontend debe mostrar "Jobs by Adzuna".
ADZUNA_APP_ID=tu_app_id_de_adzuna
ADZUNA_APP_KEY=tu_app_key_de_adzuna

# === DeepSeek (IA para evaluación de ofertas) ===
# API key de tu cuenta de DeepSeek.
# Obtenela en: https://platform.deepseek.com → API Keys.
# Usamos DeepSeek directo (endpoint: https://api.deepseek.com/v1/chat/completions).
# La variable anteriormente documentada como OPENCODE_GO_API_KEY fue reemplazada
# por esta para alinear con el código real.
DEEPSEEK_API_KEY=tu_api_key_de_deepseek

# === Servidor ===
NODE_ENV=development
PUERTO=3000
POSTGRES_MAX_INTENTOS_CONEXION=10
POSTGRES_ESPERA_REINTENTO_MS=3000

# Si usás una base remota que exige SSL, forzalo explícitamente.
# Ejemplo en Railway cuando no llega DATABASE_URL: PGSSLMODE=require
PGSSLMODE=disable

# === Seguridad ===
# Orígenes permitidos para CORS (separados por coma si hay varios).
# En producción esta variable es OBLIGATORIA. El servidor no arrancará sin ella.
CORS_ORIGEN=http://localhost:4200,https://busca-empleos.vercel.app

# Secreto HMAC para firmar los cursores de sincronización de ofertas.
# En producción es OBLIGATORIO: sin esta variable el backend no inicia.
# En desarrollo y test se genera un secreto efímero con warning; esos cursores
# dejan de ser válidos al reiniciar. Si se rota el secreto, descarto el cursor
# pendiente y reinicio la sincronización.
CURSOR_SINCRONIZACION_SECRETO=generar_un_secreto_aleatorio_largo

# === Diagnóstico ===
# Habilita el endpoint GET /api/ofertas/diagnostico/persistencia (solo en dev).
# Solo funciona si NO está en producción. Nunca incluye credenciales ni connection strings.
# Usalo solo temporalmente para verificar conectividad.
HABILITAR_DIAGNOSTICO_PERSISTENCIA=false

# === Logging ===
# Nivel de verbosidad del logger interno.
# Valores posibles: debug, info (default), warn, error.
# En producción se recomienda 'warn' o 'error' para reducir lineas de log.
LOG_LEVEL=info

# === Firebase Admin ===
# Ruta al archivo de credenciales del Service Account de Firebase.
# Descargarlo desde: Firebase Console > Configuración del proyecto > Cuentas de servicio
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# En Railway conviene usar el JSON completo en una variable, no un archivo físico.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}

# === Autenticación ===
# Email del único usuario autorizado a usar la aplicación.
EMAIL_AUTORIZADO=tu_email@gmail.com

# === Notificación por email (SMTP) ===
# Servicio de resumen automático post-ciclo. Si falta alguna de las variables
# obligatorias (SMTP_HOST, SMTP_USER, SMTP_PASS, EMAIL_NOTIFICACION_DESTINO),
# el email se deshabilita silenciosamente (soft-disable): no crashea la app.
# Puerto 465 usa SSL/TLS directo (secure: true). Puerto 587 usa STARTTLS (secure: false).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
SMTP_FROM=tu_email@gmail.com
EMAIL_NOTIFICACION_DESTINO=marcostoledo96@gmail.com

# === Base de datos ===
PGHOST=localhost
PGPORT=5432
PGDATABASE=busca_empleos
PGUSER=postgres
PGPASSWORD=tu_contraseña_aqui

# === Apify ===
APIFY_TOKEN=tu_token_de_apify

# === Jooble ===
# API key gratuita. Registrarse en: https://jooble.org/api/about
JOOBLE_API_KEY=tu_api_key_de_jooble

# === InfoJobs España (API oficial) ===
# Registrarse en: https://developer.infojobs.net para obtener las credenciales.
# Solo acepta ofertas de remoto puro (teleworking=solo-teletrabajo).
INFOJOBS_CLIENT_ID=tu_client_id_de_infojobs
INFOJOBS_CLIENT_SECRET=tu_client_secret_de_infojobs

# === Adzuna (API REST oficial) ===
# Registrarse en: https://developer.adzuna.com para obtener las credenciales.
# Requiere ambas variables para funcionar. Si solo una está presente, el servidor lanza error.
# Si ninguna está configurada, Adzuna se deshabilita automáticamente (soft-disable).
# Atribución requerida: el frontend debe mostrar "Jobs by Adzuna".
ADZUNA_APP_ID=tu_app_id_de_adzuna
ADZUNA_APP_KEY=tu_app_key_de_adzuna

# === OpenCode Go (IA para evaluación de ofertas) ===
# API key de tu suscripción OpenCode Go.
# Obtenela en: https://opencode.ai → suscripción Go → API key.
# También está en: ~/.local/share/opencode/auth.json → opencode-go.key
OPENCODE_GO_API_KEY=tu_api_key_de_opencode_go

# === Servidor ===
NODE_ENV=development
PUERTO=3000
POSTGRES_MAX_INTENTOS_CONEXION=10
POSTGRES_ESPERA_REINTENTO_MS=3000

# Si usás una base remota que exige SSL, forzalo explícitamente.
# Ejemplo en Railway cuando no llega DATABASE_URL: PGSSLMODE=require
PGSSLMODE=disable

# === Seguridad ===
# Orígenes permitidos para CORS (separados por coma si hay varios).
CORS_ORIGEN=http://localhost:4200,https://busca-empleos.vercel.app

# === Firebase Admin ===
# Ruta al archivo de credenciales del Service Account de Firebase.
# Descargarlo desde: Firebase Console > Configuración del proyecto > Cuentas de servicio
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# En Railway conviene usar el JSON completo en una variable, no un archivo físico.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}

# === Autenticación ===
# Email del único usuario autorizado a usar la aplicación.
EMAIL_AUTORIZADO=tu_email@gmail.com

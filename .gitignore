# Sistema operativo
Thumbs.db
.DS_Store

# IDE
.vscode/
.idea/

# Variables de entorno (contienen credenciales)
**/.env

# Archivos de entorno del frontend (contienen Firebase API Key)
# Los valores reales nunca deben quedar en el historial de git.
# Para desarrollo local: copiar el .example correspondiente y completar los valores.
# Para Vercel: el script scripts/generar-env.js genera environment.prod.ts desde las variables de Vercel.
frontend/src/environments/environment.ts
frontend/src/environments/environment.prod.ts

# CV y datos personales
docs/cv.md
docs/*.pdf
docs/*.docx

# Artefactos de herramientas de desarrollo
.playwright-mcp/

# Prototipos y archivos temporales de diseño
docs/login

# Dependencias (cada subcarpeta tiene su propio .gitignore pero esto cubre la raíz)
node_modules/
